{
  "$schema": "https://raw.githubusercontent.com/earendil-works/pi/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
  "name": "custom-pi-quantum",
  "vars": {
    "bg": "#08060d",
    "fg": "#e2e8f0",
    "accentPink": "#ff007f",
    "accentCyan": "#00f0ff",
    "accentPurple": "#a122ff",
    "accentGreen": "#00ffcc",
    "accentYellow": "#ffd700",
    "accentCrimson": "#ff3366",
    "muted": "#4c3a60",
    "dim": "#231834"
  },
  "colors": {
    "accent": "accentPink",
    "border": "muted",
    "borderAccent": "accentCyan",
    "borderMuted": "dim",
    "success": "accentGreen",
    "error": "accentCrimson",
    "warning": "accentYellow",
    "muted": "muted",
    "dim": "dim",
    "text": "fg",
    "thinkingText": "muted",
    "selectedBg": "#1d102e",
    "userMessageBg": "#150b24",
    "userMessageText": "fg",
    "customMessageBg": "#1d102e",
    "customMessageText": "fg",
    "customMessageLabel": "accentPurple",
    "toolPendingBg": "#0e0817",
    "toolSuccessBg": "#081d19",
    "toolErrorBg": "#210912",
    "toolTitle": "accentCyan",
    "toolOutput": "muted",
    "mdHeading": "accentPink",
    "mdLink": "accentCyan",
    "mdLinkUrl": "muted",
    "mdCode": "accentGreen",
    "mdCodeBlock": "fg",
    "mdCodeBlockBorder": "dim",
    "mdQuote": "muted",
    "mdQuoteBorder": "accentPurple",
    "mdHr": "dim",
    "mdListBullet": "accentPink",
    "toolDiffAdded": "accentGreen",
    "toolDiffRemoved": "accentCrimson",
    "toolDiffContext": "muted",
    "syntaxComment": "#5c4f75",
    "syntaxKeyword": "accentPink",
    "syntaxFunction": "accentCyan",
    "syntaxVariable": "fg",
    "syntaxString": "accentGreen",
    "syntaxNumber": "accentYellow",
    "syntaxType": "accentPurple",
    "syntaxOperator": "accentCyan",
    "syntaxPunctuation": "muted",
    "thinkingOff": "dim",
    "thinkingMinimal": "muted",
    "thinkingLow": "accentPurple",
    "thinkingMedium": "accentPink",
    "thinkingHigh": "accentCyan",
    "thinkingXhigh": "accentCrimson",
    "bashMode": "accentYellow"
  },
  "symbols": {
    "preset": "unicode",
    "overrides": {
      "spinner": "✦",
      "prompt": "❖",
      "bullet": "◆",
      "check": "✔",
      "cross": "✖",
      "arrow": "➜",
      "branch": "⎇",
      "gear": "⚙",
      "star": "★"
    }
  }
}

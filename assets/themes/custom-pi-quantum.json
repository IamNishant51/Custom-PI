{
  "$schema": "https://raw.githubusercontent.com/earendil-works/pi/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
  "name": "custom-pi-quantum",
  "vars": {
    "bg": "#0c0c0c",
    "fg": "#d4d4d4",
    "gray100": "#e5e5e5",
    "gray200": "#b0b0b0",
    "gray300": "#808080",
    "gray400": "#555555",
    "gray500": "#3a3a3a",
    "gray600": "#2a2a2a",
    "gray700": "#1a1a1a",
    "gray800": "#141414",
    "gray850": "#111111",
    "gray900": "#0e0e0e",
    "subtleGreen": "#7ab87a",
    "subtleRed": "#c97a7a",
    "subtleYellow": "#c9b07a"
  },
  "colors": {
    "accent": "gray200",
    "border": "gray500",
    "borderAccent": "gray300",
    "borderMuted": "gray600",
    "success": "subtleGreen",
    "error": "subtleRed",
    "warning": "subtleYellow",
    "muted": "gray300",
    "dim": "gray600",
    "text": "fg",
    "thinkingText": "gray300",
    "selectedBg": "gray800",
    "userMessageBg": "gray850",
    "userMessageText": "gray100",
    "customMessageBg": "gray900",
    "customMessageText": "fg",
    "customMessageLabel": "gray200",
    "toolPendingBg": "gray850",
    "toolSuccessBg": "gray800",
    "toolErrorBg": "gray800",
    "toolTitle": "gray200",
    "toolOutput": "fg",
    "mdHeading": "gray100",
    "mdLink": "gray200",
    "mdLinkUrl": "gray400",
    "mdCode": "gray100",
    "mdCodeBlock": "fg",
    "mdCodeBlockBorder": "gray600",
    "mdQuote": "gray400",
    "mdQuoteBorder": "gray500",
    "mdHr": "gray600",
    "mdListBullet": "gray300",
    "toolDiffAdded": "subtleGreen",
    "toolDiffRemoved": "subtleRed",
    "toolDiffContext": "gray400",
    "syntaxComment": "gray500",
    "syntaxKeyword": "gray100",
    "syntaxFunction": "gray200",
    "syntaxVariable": "fg",
    "syntaxString": "gray100",
    "syntaxNumber": "gray200",
    "syntaxType": "gray200",
    "syntaxOperator": "gray300",
    "syntaxPunctuation": "gray400",
    "thinkingOff": "gray600",
    "thinkingMinimal": "gray400",
    "thinkingLow": "gray300",
    "thinkingMedium": "gray200",
    "thinkingHigh": "gray100",
    "thinkingXhigh": "fg",
    "bashMode": "subtleYellow"
  },
  "symbols": {
    "preset": "unicode",
    "overrides": {
      "spinner": "✦",
      "prompt": "❖",
      "bullet": "◆",
      "check": "✔",
      "cross": "✖",
      "arrow": "➜",
      "branch": "⎇",
      "gear": "⚙",
      "star": "★"
    }
  }
}

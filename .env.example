# ── Server ──────────────────────────────────────
PORT=4321
HOST=0.0.0.0
NODE_ENV=production
PI_DIR=./data

# ── API Keys (stored in encrypted vault) ────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Local Model Providers ────────────────────────
LM_STUDIO_URL=http://127.0.0.1:1234/v1
OLLAMA_URL=http://127.0.0.1:11434

# ── Social Media ──────────────────────────────────
BLUESKY_IDENTIFIER=user.bsky.social   # Email/handle
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ── Email (Bridge) ────────────────────────────────
SOCIAL_BRIDGE_URL=http://localhost:9877
EMAIL_BRIDGE_URL=http://localhost:9878

# ── Notifications ─────────────────────────────────
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=pi-custom-pack-alerts

# ── Webhooks ──────────────────────────────────────
WEBHOOK_SECRET=your-webhook-signing-secret

# ── Auth ──────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-64-char-string
API_KEY=optional-static-api-key-for-tools

# ── Docker ────────────────────────────────────────
# Set in docker-compose.gpu.yml for GPU passthrough
# NVIDIA_VISIBLE_DEVICES=all

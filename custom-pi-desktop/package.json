  "version": "1.11.0",
  "description": "Custom-PI Desktop App — AI coding agent with swarm intelligence",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "dev:watch": "tsc --watch &  electron .",

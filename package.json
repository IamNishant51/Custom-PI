{
  "name": "custom-pi",
  "version": "1.11.0",
  "description": "Autonomous AI coding agent with knowledge graph memory, DAG swarm orchestration, deployment pipelines, service health monitoring, and adaptive resource management",
  "main": "bin/cli.js",
  "bin": {
    "custom-pi": "bin/cli.js",
    "custom-pi-web": "bin/web.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "update-and-publish": "node scripts/update-and-publish.js",
    "release": "node scripts/create-release.js",
    "deploy-wiki": "node scripts/deploy-wiki.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:web": "cd assets/web/client && npm install && npm run build",
    "web": "node bin/web.js",
    "desktop:dev": "cd custom-pi-desktop && npm run dev",
    "desktop:build": "cd custom-pi-desktop && npm run build",
    "desktop:dist:win": "cd custom-pi-desktop && npm run dist:win",
    "desktop:dist:mac": "cd custom-pi-desktop && npm run dist:mac",
    "desktop:dist:linux": "cd custom-pi-desktop && npm run dist:linux"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.77.0",
    "@earendil-works/pi-coding-agent": "0.77.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/static": "^8.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.0.2",
    "better-sqlite3": "^12.10.0",
    "cli-highlight": "^2.1.11",
    "fastify": "^5.3.2",
    "glob": "^13.0.6",
    "imapflow": "^1.3.5",
    "nodemailer": "^8.0.10",
    "playwright": "^1.60.0",
    "react-router-dom": "^7.17.0",
    "sharp": "^0.35.1",
    "yaml": "^2.9.0"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "coding-agent",
    "agent-swarm",
    "multi-agent",
    "tui",
    "cli-tui",
    "terminal",
    "autonomous-agent",
    "developer-tools",
    "developer-productivity",
    "claude-code",
    "gemini",
    "openai",
    "ollama",
    "rag-memory"
  ],
  "author": "Nishant Unavane <iamnishantunavane@gmail.com> (https://nishant-unavane.vercel.app)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IamNishant51/Custom-PI.git"
  },
  "bugs": {
    "url": "https://github.com/IamNishant51/custom-pi/issues"
  },
  "homepage": "https://github.com/IamNishant51/custom-pi#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true,
  "overrides": {
    "protobufjs": ">=7.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.7"
  }
}

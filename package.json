{
  "name": "custom-pi",
  "version": "1.1.0",
  "description": "Customized Pi Coding Agent with parallel subagents, premium TUI dashboard styling, and session memory tracking",
  "main": "bin/cli.js",
  "bin": {
    "custom-pi": "bin/cli.js",
    "custom-pi-web": "bin/web.js"
  },
  "scripts": {
    "update-and-publish": "node scripts/update-and-publish.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:web": "cd assets/web/client && npm install && npm run build",
    "web": "node bin/web.js"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.77.0",
    "@earendil-works/pi-ai": "0.77.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.3.2",
    "@fastify/websocket": "^11.0.2",
    "@fastify/static": "^8.1.1",
    "yaml": "^2.9.0"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "coding-agent",
    "agent-swarm",
    "multi-agent",
    "tui",
    "cli-tui",
    "terminal",
    "autonomous-agent",
    "developer-tools",
    "developer-productivity",
    "claude-code",
    "gemini",
    "openai",
    "ollama",
    "rag-memory"
  ],
  "author": "Nishant Unavane <iamnishantunavane@gmail.com> (https://nishant-unavane.vercel.app)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IamNishant51/Custom-PI.git"
  },
  "bugs": {
    "url": "https://github.com/IamNishant51/custom-pi/issues"
  },
  "homepage": "https://github.com/IamNishant51/custom-pi#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true,
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
